# ── NetProbe Server — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Authentication ────────────────────────────────────────────────────────────
# API key required on every request (header: X-API-Key or query: ?key=).
# Leave empty to disable auth entirely (development only — never do this publicly).
NETPROBE_API_KEY=change-me-to-a-long-random-secret

# ── Server bind ───────────────────────────────────────────────────────────────
NETPROBE_HOST=0.0.0.0
NETPROBE_PORT=8765

# ── Logging ───────────────────────────────────────────────────────────────────
# Uvicorn log level: debug | info | warning | error | critical
NETPROBE_LOG_LEVEL=info

# ── Scan limits ───────────────────────────────────────────────────────────────
# Maximum number of hosts expanded from a single CIDR range
NETPROBE_MAX_CIDR_HOSTS=1024

# Maximum number of ports allowed in a single port scan request
NETPROBE_MAX_SCAN_PORTS=10000

# Number of concurrent threads for TCP port scanning
NETPROBE_SCAN_THREADS=100

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * to allow all.
# Set to your Cloudflare hostname when deploying remotely, e.g.:
#   NETPROBE_CORS_ORIGINS=https://netprobe.yourdomain.com
NETPROBE_CORS_ORIGINS=*
